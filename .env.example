# ──────────────────────────────────────────────────────────────
# OpenKnots Code Editor – Environment Variables
# Copy this file to .env.local and fill in the values.
# ──────────────────────────────────────────────────────────────

# ── WorkOS AuthKit ───────────────────────────────────────────
# Required for authentication via @workos-inc/authkit-nextjs.
# Obtain these from your WorkOS Dashboard → API Keys.
WORKOS_API_KEY=
WORKOS_CLIENT_ID=

# The redirect URI registered in your WorkOS Dashboard.
# For local dev this is typically http://localhost:3000/callback.
WORKOS_REDIRECT_URI=http://localhost:3000/callback
NEXT_PUBLIC_WORKOS_REDIRECT_URI="http://localhost:3000/callback"

# A random 32+ character string used to encrypt the session cookie.
# Generate one with: openssl rand -hex 32
WORKOS_COOKIE_PASSWORD=

# ── GitHub ───────────────────────────────────────────────────
# Personal access token used as a fallback when no Bearer token
# is provided in the Authorization header of GitHub API requests.
# Scopes needed depend on your use case (e.g. repo, read:org).
GITHUB_TOKEN=

# ── IP Allowlist ─────────────────────────────────────────────
# Comma-separated list of IPs or CIDR ranges allowed to access
# the application. Supports individual IPs and CIDR notation.
#   Examples:
#     ALLOWED_IPS=203.0.113.42,198.51.100.7
#     ALLOWED_IPS=203.0.113.0/24,198.51.100.7
#
# Set to * to disable the IP restriction (allow all traffic).
# If unset or empty, all traffic is blocked (fail-closed).
# Localhost is auto-allowed in development regardless.
ALLOWED_IPS=*

# ── User Allowlist ────────────────────────────────────────────
# Restrict access to a single WorkOS user. Both must match if set.
# Find these in the WorkOS Dashboard → Users after the user signs in.
ALLOWED_USER_EMAIL=
ALLOWED_USER_ID=

# ── App URL ──────────────────────────────────────────────────
# Public-facing URL of the application, used for CORS headers.
# In production set this to your deployed domain.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Tauri Desktop Build (optional) ───────────────────────────
# Used by `next.config.ts` to switch Next.js to static export mode
# during Tauri desktop builds.
# Tauri CLI usually injects this automatically; for normal web/dev
# usage you should leave it unset.
# TAURI_ENV_PLATFORM=darwin
